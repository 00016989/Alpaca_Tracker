# ──────────────────────────────────────────────────────────────────────────
# ALDash account credentials
# ──────────────────────────────────────────────────────────────────────────
# 1. Copy this file to ".streamlit/secrets.toml" (same folder).
# 2. Fill in the API key + secret for each Alpaca account.
# 3. Set paper = true for paper accounts, false for live (real-money) accounts.
# 4. NEVER commit secrets.toml — it is already in .gitignore.
#
# Get keys from: https://app.alpaca.markets/  ->  account dropdown  ->  API Keys
# (Generate separate keys per account. Paper keys come from the paper dashboard.)
#
# You can list as many [[accounts]] blocks as you like. The dashboard supports
# any mix of live and paper accounts.

# Password to access the dashboard (REQUIRED for public deployments).
app_password = "change-me-to-a-strong-password"

[[accounts]]
name = "Main (Live)"
api_key = "YOUR_LIVE_KEY_1"
api_secret = "YOUR_LIVE_SECRET_1"
paper = false

[[accounts]]
name = "Swing (Live)"
api_key = "YOUR_LIVE_KEY_2"
api_secret = "YOUR_LIVE_SECRET_2"
paper = false

[[accounts]]
name = "Test (Paper)"
api_key = "YOUR_PAPER_KEY"
api_secret = "YOUR_PAPER_SECRET"
paper = true
