# ──────────────────────────────────────────────────────────────────────────
# ALDash credentials  —  copy this file to ".env" and fill in your keys.
# ──────────────────────────────────────────────────────────────────────────
# One block per account. Numbers must be consecutive: 1, 2, 3, ...
# PAPER=true for paper accounts, PAPER=false for live (real-money) accounts.
#
# Get keys at https://app.alpaca.markets -> account menu -> API Keys
# .env is git-ignored — your keys never leave your machine.

# Password to access the dashboard (REQUIRED before deploying publicly).
# Leave blank for local-only use. Pick something long and unguessable.
ALDASH_PASSWORD=change-me-to-a-strong-password

# ---- Account 1 ----
ALDASH_ACCOUNT_1_NAME=Main (Live)
ALDASH_ACCOUNT_1_KEY=YOUR_LIVE_KEY_1
ALDASH_ACCOUNT_1_SECRET=YOUR_LIVE_SECRET_1
ALDASH_ACCOUNT_1_PAPER=false

# ---- Account 2 ----
ALDASH_ACCOUNT_2_NAME=Swing (Live)
ALDASH_ACCOUNT_2_KEY=YOUR_LIVE_KEY_2
ALDASH_ACCOUNT_2_SECRET=YOUR_LIVE_SECRET_2
ALDASH_ACCOUNT_2_PAPER=false

# ---- Account 3 ----
ALDASH_ACCOUNT_3_NAME=Test (Paper)
ALDASH_ACCOUNT_3_KEY=YOUR_PAPER_KEY
ALDASH_ACCOUNT_3_SECRET=YOUR_PAPER_SECRET
ALDASH_ACCOUNT_3_PAPER=true
